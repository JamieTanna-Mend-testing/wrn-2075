{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "customManagers": [
    {
      "description": "Test github-tags datasource via regex manager",
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.env\\.example$/"
      ],
      "matchStrings": [
        "TOOL_VERSION=(?<currentValue>[^\\n]+)\\s+#renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\n]+)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "at any time"
    ]
  }
}
